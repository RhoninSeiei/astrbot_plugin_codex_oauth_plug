{
  "runtime": {
    "description": "运行设置",
    "type": "object",
    "hint": "插件注册的 provider 类型为 oauth_plug_openai_codex_chat_completion。Provider 页面中新建该类型后，模型测试和聊天会通过插件保存的 OAuth 凭据请求 Codex backend。",
    "items": {
      "enabled": {
        "description": "启用 OAuth_plug provider",
        "type": "bool",
        "default": true
      },
      "base_url": {
        "description": "Codex backend 地址",
        "type": "string",
        "default": "https://chatgpt.com/backend-api/codex"
      },
      "proxy": {
        "description": "HTTP 代理",
        "type": "string",
        "hint": "示例：http://127.0.0.1:7890。留空则不使用代理。",
        "default": ""
      },
      "models": {
        "description": "模型列表",
        "type": "text",
        "hint": "每行填写一个模型 ID，首行作为默认模型。示例：gpt-5.6-sol。",
        "default": "gpt-5.6-sol\ngpt-5.6-terra\ngpt-5.6-luna"
      },
      "oauth_refresh_skew_seconds": {
        "description": "提前刷新秒数",
        "type": "int",
        "default": 300
      }
    }
  },
  "oauth": {
    "description": "OAuth 凭据",
    "type": "object",
    "hint": "授权、刷新和测试通过管理员聊天命令或插件 Web API 触发。此处保留运行期调用 Codex backend 所需的凭据字段。",
    "items": {
      "auth_mode": {
        "description": "认证模式",
        "type": "string",
        "default": "manual"
      },
      "oauth_provider": {
        "description": "OAuth provider",
        "type": "string",
        "default": ""
      },
      "oauth_access_token": {
        "description": "Access token",
        "type": "text",
        "default": ""
      },
      "oauth_refresh_token": {
        "description": "Refresh token",
        "type": "text",
        "default": ""
      },
      "oauth_expires_at": {
        "description": "过期时间",
        "type": "string",
        "default": ""
      },
      "oauth_account_id": {
        "description": "ChatGPT account id",
        "type": "string",
        "default": ""
      }
    }
  },
  "advanced": {
    "description": "高级设置",
    "type": "object",
    "items": {
      "generated_image_dir": {
        "description": "生图保存目录",
        "type": "string",
        "hint": "留空时保存到 AstrBot data/generated/oauth_plug_openai_codex_images。",
        "default": ""
      }
    }
  }
}
